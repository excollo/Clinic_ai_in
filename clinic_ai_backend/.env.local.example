API_HOST=0.0.0.0
API_PORT=8000
MONGODB_URL=mongodb://localhost:27017/clinic_ai
MONGODB_DB_NAME=clinic_ai
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o-mini
AZURE_SPEECH_KEY=your_azure_speech_key
AZURE_SPEECH_REGION=centralindia
AZURE_SPEECH_ENDPOINT=
WHATSAPP_ACCESS_TOKEN=your_meta_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_VERIFY_TOKEN=your_verify_token
WHATSAPP_API_VERSION=v21.0
WHATSAPP_INTAKE_TEMPLATE_NAME=opening_msg
WHATSAPP_INTAKE_TEMPLATE_LANG_EN=en_US
WHATSAPP_INTAKE_TEMPLATE_LANG_HI=hi
WHATSAPP_INTAKE_TEMPLATE_PARAM_COUNT=1
INTAKE_USE_LLM_MESSAGE=false
INTAKE_REQUIRE_ALL_AGENTS=true
INTAKE_STRICT_VALIDATION=true
ENCRYPTION_KEY=generate_a_stable_fernet_key
JWT_SECRET_KEY=change-this-to-a-strong-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
CORS_ORIGINS=http://localhost:5173
MAX_AUDIO_SIZE_MB=25
TRANSCRIPTION_TIMEOUT_SEC=120
TRANSCRIPTION_JOB_TIMEOUT_SEC=3600
USE_LOCAL_ADAPTERS=true
LOCAL_AUDIO_STORAGE_PATH=/tmp/clinic_audio

