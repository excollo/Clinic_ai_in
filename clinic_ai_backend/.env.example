OPENAI_API_KEY="sk-p....."
OPENAI_MODEL=gpt-4o-mini
MONGODB_URL=mongodb+srv://himanshu:Himanshu%4029@clinicaiindia.q92ubxx.mongodb.net/clinic_ai?retryWrites=true&w=majority&appName=clinicaiindia
MONGODB_DB_NAME=clinic_ai
CORS_ORIGINS=http://localhost:3000
LOG_LEVEL=INFO
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe
QUEUE_CONNECTION_STRING=
# Transcription: jobs use MongoDB collection `transcription_queue` (not Azure Queue).
# Audio bytes: GridFS on real MongoDB, or temp files under LOCAL_AUDIO_STORAGE_PATH when DB is not PyMongo.
STORAGE_PROVIDER=local
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_API_KEY=
WHATSAPP_PHONE_NUMBER_ID="1016488831554032"
WHATSAPP_TEMPLATE_POST_VISIT_RECAP=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_API_VERSION=v21.0
WHATSAPP_INTAKE_TEMPLATE_NAME="opening_msg"
WHATSAPP_INTAKE_TEMPLATE_LANG_EN=en_US
WHATSAPP_INTAKE_TEMPLATE_LANG_HI=hi
WHATSAPP_INTAKE_TEMPLATE_PARAM_COUNT=1
# Intake generation feature flags (default behavior remains unchanged).
INTAKE_USE_LLM_MESSAGE=false
INTAKE_REQUIRE_ALL_AGENTS=true
INTAKE_STRICT_VALIDATION=true
# Follow-up reminder WhatsApp: short fixed lines for T-3d, day-before visit, and immediate ping.
# Default dedicated template is follow_up_1 (set same value on Render).
WHATSAPP_FOLLOWUP_TEMPLATE_NAME="follow_up_1"
WHATSAPP_FOLLOWUP_TEMPLATE_LANG_EN=en_US
WHATSAPP_FOLLOWUP_TEMPLATE_LANG_HI=hi
WHATSAPP_FOLLOWUP_TEMPLATE_PARAM_COUNT=1
# Post-visit summary WhatsApp: template body = full generated patient summary text. Empty falls back to intake template only (not the follow-up template).
WHATSAPP_POST_VISIT_TEMPLATE_NAME=
WHATSAPP_POST_VISIT_TEMPLATE_LANG_EN=en_US
WHATSAPP_POST_VISIT_TEMPLATE_LANG_HI=hi
WHATSAPP_POST_VISIT_TEMPLATE_PARAM_COUNT=1
# Optional: require matching X-Cron-Secret on POST /workflow/follow-up-reminders/run
FOLLOW_UP_REMINDER_CRON_SECRET=
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=
AZURE_SPEECH_ENDPOINT=
TRANSCRIPTION_CONFIDENCE_THRESHOLD=0.75
TRANSCRIPTION_MANUAL_REVIEW_RATIO_THRESHOLD=0.25
MAX_AUDIO_SIZE_MB=25
ALLOWED_AUDIO_MIME_TYPES=audio/wav,audio/mpeg,audio/mp3,audio/x-wav,audio/mp4,audio/webm,audio/m4a,audio/x-m4a
TRANSCRIPTION_MAX_RETRIES=3
# Per-chunk HTTP timeout for Azure short-audio REST (each POST is one chunk of audio).
TRANSCRIPTION_TIMEOUT_SEC=120
# Whole-job wall clock (download + ffmpeg + all chunks). Raise for 10+ minute recordings.
TRANSCRIPTION_JOB_TIMEOUT_SEC=3600
# Azure short-audio REST accepts only ~60s per request (see Microsoft Learn). We split longer WAVs into chunks of this many seconds (requires ffmpeg on the worker).
TRANSCRIPTION_SHORT_AUDIO_MAX_SECONDS=55
TRANSCRIPTION_CHUNK_SECONDS=50
# Overlap (seconds) between chunk windows; reduces dropped words at boundaries (1–2 typical).
TRANSCRIPTION_CHUNK_OVERLAP_SECONDS=1.5
# Per-chunk retries for empty STT or 429/502/503 from Azure short-audio REST.
TRANSCRIPTION_CHUNK_MAX_STT_RETRIES=3
# Set true to log byte sizes and chunk counts per job (INFO).
TRANSCRIPTION_DEBUG_BYTES=false
# OpenAI dialogue structuring: max characters per contiguous transcript slice (ordered merge).
STRUCTURE_DIALOGUE_MAX_CHUNK_CHARS=12000
USE_LOCAL_ADAPTERS=true
LOCAL_AUDIO_STORAGE_PATH=/tmp/clinic_audio
MSG91_API_KEY=
MSG91_TEMPLATE_ID=
JWT_SECRET_KEY=change-this-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24
